@startuml
title Frontend Code - Settings Module
left to right direction
skinparam componentStyle rectangle

component "Settings" as Settings
component "DataContext" as DataContext
component "systemSettingsService" as SystemSettingsService
component "monthlyRainfallService" as MonthlyRainfallService
component "api" as ApiClient
database "Backend API" as BackendApi

Settings ..> DataContext : useData()\nsettings, rainfallData,\nupdateSettings(), addRainfallData()

DataContext --> SystemSettingsService : findSystemSettings()\nupdateSystemSettings()
DataContext --> MonthlyRainfallService : findByYear()\nsave()

SystemSettingsService --> ApiClient : apiFetch('/system-settings')
MonthlyRainfallService --> ApiClient : apiFetch('/monthly-rainfall')
ApiClient --> BackendApi : HTTP/JSON

@enduml
