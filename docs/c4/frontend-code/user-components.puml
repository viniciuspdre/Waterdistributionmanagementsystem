@startuml
title Frontend Code - User Module
left to right direction
skinparam componentStyle rectangle

component "UserProfile" as UserProfile
component "Header" as Header
component "AuthContext" as AuthContext
component "userService" as UserService
component "api" as ApiClient
database "Backend API" as BackendApi

UserProfile ..> AuthContext : useAuth()\nuser, updateUser()
Header ..> AuthContext : useAuth()\nuser, logout()

AuthContext --> UserService : updateUser()
UserService --> ApiClient : apiFetch('/users/{id}')
ApiClient --> BackendApi : HTTP/JSON

@enduml
